generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContributionStatus {
  WAITING
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentMethodType {
  PROMPTPAY
  BANK_TRANSFER
  TRUEMONEY
}

model Member {
  id           Int                   @id @default(autoincrement())
  username     String                @unique
  email        String                @unique
  passwordHash String                @map("password_hash")
  role         String                @default("MEMBER")
  status       MemberStatus          @default(ACTIVE)
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  contributions ContributionRequest[]

  @@map("members")
}

model PaymentMethod {
  id           Int                   @id @default(autoincrement())
  methodType   PaymentMethodType     @map("method_type")
  accountName  String                @map("account_name")
  accountNo    String                @map("account_no")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  contributions ContributionRequest[]

  @@map("payment_methods")
}

model ContributionRequest {
  id              Int               @id @default(autoincrement())
  memberId        Int               @map("member_id")
  paymentMethodId Int               @map("payment_method_id")
  amount          Decimal           @db.Decimal(12, 2)
  referenceCode   String            @unique @map("reference_code")
  status          ContributionStatus @default(WAITING)
  expiresAt       DateTime          @map("expires_at")
  paidAt          DateTime?         @map("paid_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  member          Member            @relation(fields: [memberId], references: [id])
  paymentMethod   PaymentMethod     @relation(fields: [paymentMethodId], references: [id])
  qrSession       QrSession?

  @@index([memberId])
  @@index([status, expiresAt])
  @@index([referenceCode])
  @@index([createdAt(sort: Desc)])
  @@map("contribution_requests")
}

model QrSession {
  id        Int                @id @default(autoincrement())
  requestId Int                @unique @map("request_id")
  qrData    String             @map("qr_data")
  expiresAt DateTime           @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")
  request   ContributionRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([expiresAt])
  @@map("qr_sessions")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model MasterAdmin {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name        String    @db.VarChar(255)
  role        String    @default("ADMIN") @db.VarChar(20)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @timestamptz()

  deposits Deposit[]

  @@map("master_admins")
}

model Merchant {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  name          String    @db.VarChar(255)
  businessName  String    @map("business_name") @db.VarChar(255)
  taxId         String?   @map("tax_id") @db.VarChar(50)
  status        String    @default("ACTIVE") @db.VarChar(20)
  balance       Decimal   @default(0) @db.Decimal(19, 4)
  lockedBalance Decimal   @default(0) @map("locked_balance") @db.Decimal(19, 4)
  version       Int       @default(1)
  settings      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at") @timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @timestamptz()

  merchantUsers           MerchantUser[]
  merchantDepositAccounts MerchantDepositAccount[]
  deposits                Deposit[]
  transactions            Transaction[]
  auditLogs               AuditLog[]

  @@map("merchants")
}

model MerchantUser {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  email      String   @db.VarChar(255)
  name       String   @db.VarChar(255)
  role       String   @default("CASHIER") @db.VarChar(20)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @timestamptz()

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deposits  Deposit[]

  @@unique([merchantId, email])
  @@map("merchant_users")
}

model MerchantDepositAccount {
  id            String   @id @default(uuid()) @db.Uuid
  merchantId    String   @map("merchant_id") @db.Uuid
  bankName      String   @map("bank_name") @db.VarChar(255)
  accountNumber String   @map("account_number") @db.VarChar(100)
  accountName   String   @map("account_name") @db.VarChar(255)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at") @timestamptz()

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("merchant_deposit_accounts")
}

model Deposit {
  id            String    @id @default(uuid()) @db.Uuid
  merchantId    String    @map("merchant_id") @db.Uuid
  amount        Decimal   @db.Decimal(19, 4)
  status        String    @default("PENDING") @db.VarChar(20)
  referenceCode String    @unique @map("reference_code") @db.VarChar(100)
  slipUrl       String?   @map("slip_url")
  verifiedBy    String?   @map("verified_by") @db.Uuid
  verifiedAt    DateTime? @map("verified_at") @timestamptz()
  notes         String?
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @timestamptz()

  merchant Merchant      @relation(fields: [merchantId], references: [id])
  verifier MasterAdmin?  @relation(fields: [verifiedBy], references: [id])
  creator  MerchantUser? @relation(fields: [createdBy], references: [id])

  @@map("deposits")
}

model Transaction {
  id             String   @id @default(uuid()) @db.Uuid
  merchantId     String   @map("merchant_id") @db.Uuid
  type           String   @db.VarChar(10)
  amount         Decimal  @db.Decimal(19, 4)
  balanceBefore  Decimal  @map("balance_before") @db.Decimal(19, 4)
  balanceAfter   Decimal  @map("balance_after") @db.Decimal(19, 4)
  referenceType  String?  @map("reference_type") @db.VarChar(50)
  referenceId    String?  @map("reference_id") @db.Uuid
  description    String?
  createdAt      DateTime @default(now()) @map("created_at") @timestamptz()

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("transactions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String?  @map("merchant_id") @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  actorType  String   @map("actor_type") @db.VarChar(50)
  action     String   @db.VarChar(100)
  metadata   Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at") @timestamptz()

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@map("audit_logs")
}
